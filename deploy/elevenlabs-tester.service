[Unit]
Description=ElevenLabs Agent Tester
After=network.target

[Service]
Type=exec
User=www-data
Group=www-data
WorkingDirectory=/var/www/VAT/backend
EnvironmentFile=/var/www/VAT/.env

ExecStart=/var/www/VAT/.venv/bin/uvicorn main:app \
    --host 127.0.0.1 \
    --port 8042 \
    --workers 4

Restart=on-failure
RestartSec=30

# Hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
